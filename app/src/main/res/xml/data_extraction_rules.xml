<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup disableIfNoEncryptionCapabilities="true">
        <!-- Task and location content is excluded. Only non-content settings are
             eligible, and cloud backup requires client-side encryption. -->
        <include domain="file" path="datastore/settings.preferences_pb" />
    </cloud-backup>
    <device-transfer>
        <include domain="file" path="datastore/settings.preferences_pb" />
    </device-transfer>
</data-extraction-rules>
